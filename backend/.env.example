# AstroLearn Backend — environment variables.
# Copy to .env and fill in. .env is gitignored; .env.example is committed.

# --- App ---
APP_ENV=development                          # development | staging | production
SECRET_KEY=change-me-to-a-long-random-string # JWT signing key
LOG_LEVEL=INFO                               # DEBUG | INFO | WARNING | ERROR

# --- Database (async Postgres) ---
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/astro_db

# --- Redis (cache, session, Celery broker) ---
REDIS_URL=redis://localhost:6379/0

# --- Vector DB ---
QDRANT_URL=http://localhost:6333

# --- AI Proxy (backend → LiteLLM → providers) ---
# Model names are virtual aliases defined in configs/litellm.yaml. Swap
# providers by editing that file — no backend changes needed.
LLM_BASE_URL=http://localhost:4000
LLM_API_KEY=sk-astrolearn-dev                # must match LITELLM_MASTER_KEY below
LLM_MODEL=openai/astrolearn-llm
EMBEDDING_MODEL=openai/astrolearn-embedding

LLM_FALLBACK_MODELS=
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=60                               # seconds

# --- Provider keys (read by the litellm container, not by the backend) ---
LITELLM_MASTER_KEY=sk-astrolearn-dev         # must match LLM_API_KEY above
GROQ_API_KEY=gsk_...                         # powers astrolearn-llm + astrolearn-llm-fast
JINA_API_KEY=jina_...                        # powers astrolearn-embedding (jina.ai/?sui=apikey)

# --- Storage (uploads, generated artefacts) ---
STORAGE_ROOT=./var/storage

# --- Astronomy ---
NASA_API_KEY=your-nasa-key

# --- External tools (optional) ---
TAVILY_API_KEY=
SERPAPI_API_KEY=
